---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { readingTime } from '../utils/readingTime';
import { slugify } from '../utils/slugify';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags, category } = post.data;
const mins = readingTime(post.body);
---

<article class="card">
  <div class="post-card__top">
    <a href={`/categories/${slugify(category)}/`} class="badge badge--category">{category}</a>
    <span class="meta">
      <FormattedDate date={pubDate} />
      <span class="dot">·</span>
      <span class="read">{mins} min read</span>
    </span>
  </div>

  <h2 class="post-card__title">
    <a href={`/blog/${post.id}/`} class="clamp-2">{title}</a>
  </h2>

  <p class="post-card__desc">{description}</p>

  <div class="post-card__footer">
    {
      tags.length > 0 ? (
        <div class="tag-row">
          {tags.map((t) => (
            <a href={`/tags/${slugify(t)}/`} class="tag">{t}</a>
          ))}
        </div>
      ) : (
        <span class="meta" style="color:var(--text-muted)">No tags</span>
      )
    }
    <span class="post-card__more">Read post →</span>
  </div>
</article>
