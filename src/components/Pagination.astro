---
interface Props {
  prevUrl?: string;
  nextUrl?: string;
  currentPage: number;
  lastPage: number;
}
const { prevUrl, nextUrl, currentPage, lastPage } = Astro.props;
---

{
  lastPage > 1 && (
    <nav class="pagination" aria-label="Pagination">
      {prevUrl ? (
        <a href={prevUrl} class="page-btn">← Newer</a>
      ) : (
        <span class="page-btn disabled">← Newer</span>
      )}
      <span class="page-info">Page {currentPage} of {lastPage}</span>
      {nextUrl ? (
        <a href={nextUrl} class="page-btn">Older →</a>
      ) : (
        <span class="page-btn disabled">Older →</span>
      )}
    </nav>
  )
}
