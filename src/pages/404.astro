---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not found" description="That page does not exist.">
  <section class="container center-404">
    <p class="eyebrow">404</p>
    <h1>Page not found</h1>
    <p class="lead">The page you’re looking for doesn’t exist or has moved.</p>
    <p><a href="/" class="btn btn-primary">← Back to blog</a></p>
  </section>
</BaseLayout>
