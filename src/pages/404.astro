---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="404 — Not found"
  description="That page does not exist."
  mainClass="shell notfound"
>
  <div>
    <span class="eyebrow" style="justify-content:center">Error</span>
    <div class="notfound__code gradient-text">404</div>
    <h1>This route returned nothing</h1>
    <p>
      The page you asked for isn't here — it may have been moved, renamed, or
      never shipped. The writing, however, is still where you left it.
    </p>
    <div class="notfound__actions">
      <a class="btn btn--primary" href="/">← Back to all posts</a>
      <a class="btn btn--ghost" href="/categories/">Browse categories</a>
    </div>
    <p class="meta" style="justify-content:center;margin-top:var(--space-8)">
      <span class="mono">GET /missing</span><span class="dot">·</span><span>404 Not Found</span>
    </p>
  </div>
</BaseLayout>
