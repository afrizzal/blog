---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPublishedPosts } from '../../utils/posts';
import { slugify } from '../../utils/slugify';

const posts = await getPublishedPosts();
const counts = new Map<string, number>();
for (const p of posts) counts.set(p.data.category, (counts.get(p.data.category) ?? 0) + 1);
const categories = [...counts.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]));
---

<BaseLayout title="Categories — Afrizzal Blog" description="Browse posts by category.">
  <header class="page-header">
    <span class="eyebrow">Browse</span>
    <h1>Categories</h1>
    <p class="intro">
      Every post belongs to a single category — {categories.length} so far, ordered by how much I end up writing about each.
    </p>
  </header>

  {
    categories.length === 0 ? (
      <div class="empty">
        <div class="empty__glyph">∅</div>
        <h3>No categories yet</h3>
        <p>Categories appear here once the first post is published.</p>
      </div>
    ) : (
      <div class="cat-list">
        {categories.map(([c, n]) => (
          <a class="cat-row" href={`/categories/${slugify(c)}/`}>
            <div class="cat-row__main">
              <span class="cat-row__name">{c}</span>
            </div>
            <span class="cat-row__count">{n} post{n === 1 ? '' : 's'}</span>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
