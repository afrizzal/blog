---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  /**
   * Classes applied to <main>. Defaults to the wide list/page shell.
   * The article layout passes "shell shell--prose article"; 404 passes
   * "shell notfound". Each variant carries its own top padding.
   */
  mainClass?: string;
}

const { title, description, image, type, mainClass = 'shell page' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} type={type} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
